#参数
pCube
pDimension

#前序

### 删除cube视图 ###
if(pCube@='');
  k = 1;
  while(k<=dimsiz('}Cubes'));
    cCube = dimnm('}Cubes',k);
    vDim = '}View_'|vCube;
    if(dimensionexists(vDim)=1);
      i = 1;
      while(i<=dimsiz(vDim));
        vView = dimnm(vDim,i);
        if(subst(vView,1,4)@='Cube' % subst(vView,1,6)@='Export' % subst(vView,1,8)@='Transfer' % subst(vView,1,6)@='Import' 
        % subst(vView,1,3)@='Gen' % subst(vView,1,9)@='TempView' % subst(vView,1,7)@='Tranfer' );#此为大洋电机进程的创建视图的开头，具体到别的系统需要替换
          ViewDestory(vCube,vView); 
          i = i - 1;
        endif;
      i = i + 1;
      end;
    endif;
  k = k + 1;
  end;
else;
cCube = pCube;
vDim = '}View_'|vCube;
if(dimensionexists(vDim)=1);
  i = 1;
  while(i<=dimsiz(vDim));
    vView = dimnm(vDim,i);
    if(subst(vView,1,4)@='Cube' % subst(vView,1,6)@='Export' % subst(vView,1,8)@='Transfer' % subst(vView,1,6)@='Import' 
      % subst(vView,1,3)@='Gen' % subst(vView,1,9)@='TempView' % subst(vView,1,7)@='Tranfer' );#此为大洋电机进程的创建视图的开头，具体到别的系统需要替换
      ViewDestory(vCube,vView);
      i = i - 1;
    endif;
  i = i + 1;
  end;
endif;

