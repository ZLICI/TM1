#第一步需要输入密码解压缩
#第二步需要用密码压缩，
#第三步需要删除第一步解压完的文件

# ==============================================
# 配置项
# ==============================================
s7zPath = '"C:\Program Files\7-Zip\7z.exe"';
sSourceZip = 'C:\Users\thinkpad\Desktop\Source\test.7z';
sTempDir = 'C:\Users\thinkpad\Desktop\Source\temp_unzip';
sTargetDir = 'C:\Users\thinkpad\Desktop\Target';
sPwdExtract = '123456';
sPwdCompress = '654321';

# ==============================================
# 参数 pYearMonth (例如 202604)
# ==============================================
sYearMonth = pYearMonth;

# ==============================================
# 1. 创建目录
# ==============================================
ExecuteCommand('cmd.exe /c mkdir "' | sTempDir | '"', 1);
ExecuteCommand('cmd.exe /c mkdir "' | sTargetDir | '"', 1);

# ==============================================
# 2. 解压
# ==============================================
ExecuteCommand(s7zPath | ' x -p"' | sPwdExtract | '" "' | sSourceZip | '" -o"' | sTempDir | '" -y', 1);

# ==============================================
# 3. 重命名为 年月_原文件名
# ==============================================
ExecuteCommand('cmd.exe /c for %%f in ("' | sTempDir | '\*.txt") do ren "%%f" "' | sYearMonth | '_%%~nxf"', 1);

# ==============================================
# 4. 移动到目标文件夹
# ==============================================
ExecuteCommand('cmd.exe /c move /y "' | sTempDir | '\*.txt" "' | sTargetDir | '"', 1);

# ==============================================
# 5. 【绝对不空包】直接压缩目标文件夹里所有txt
# ==============================================
sTempZip = sTargetDir |'/'|sYearMonth | '_test.7z';
ExecuteCommand(s7zPath | ' a -p"' | sPwdCompress | '" -mhe=on "' | sTempZip | '" "' | sTargetDir | '\*.txt"', 1);

# ==============================================
# 6. 删除所有txt文件
# ==============================================
ExecuteCommand('cmd.exe /c del /q /f "' | sTargetDir | '\*.txt"', 1);

# ==============================================
# 7. 最终重命名压缩包
# ==============================================
#sFinalZip = sYearMonth | '_test2.7z';
#ExecuteCommand('cmd.exe /c ren "' | sTempZip | '" "' | sFinalZip | '"', 1);

# ==============================================
# 8. 清理临时目录
# ==============================================
ExecuteCommand('cmd.exe /c rmdir /s /q "' | sTempDir | '"', 1);

# ==============================================
# 完成
# ==============================================
